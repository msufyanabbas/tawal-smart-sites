# ──────────────────────────────────────────────────────────────────────────────
# cctv-records-web — environment template
#
# Every variable here is read from the source code (import.meta.env.VITE_*).
# Vite inlines these at BUILD time — changing them later requires `npm run
# build` again (or `docker compose build web`).
# ──────────────────────────────────────────────────────────────────────────────

# Read in src/api/client.ts. Base URL the SPA uses for all API requests.
#
# Two valid shapes:
#   • Same-origin via the nginx /api proxy (recommended for prod / compose):
#       VITE_API_BASE_URL=/api
#   • Cross-origin direct to the backend (local dev, e.g. `npm run dev`):
#       VITE_API_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=/api
