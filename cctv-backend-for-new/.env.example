# ──────────────────────────────────────────────────────────────────────────────
# cctv-backend-for-new — environment template
#
# Every variable here is read from the source code (process.env.* or
# ConfigService.get(...)). Copy this file to `.env` and fill in real values.
# `dotenv` is loaded in src/main.ts; never commit your real `.env`.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────────────────
# Read in src/app.module.ts (MongooseModule.forRoot).
MONGODB_URI=mongodb://localhost:27017/cctv

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Default signing secret for JwtModule (src/auth/auth.module.ts).
JWT_SECRET=change-me-jwt-default
# Signs the short-lived access token (15m).
JWT_ACCESS_SECRET=change-me-access-secret
# Signs the longer-lived refresh token (7d).
JWT_REFRESH_SECRET=change-me-refresh-secret

# ─── SMTP / Email ────────────────────────────────────────────────────────────
# Used by src/mail/mail.service.ts and src/reports/reports.service.ts.
EMAIL_HOST=smtp.example.com
EMAIL=no-reply@example.com
EMAIL_PASSWORD=change-me-smtp-password

# ─── Frontend URL ────────────────────────────────────────────────────────────
# Base URL of the web SPA. Used to build the password-reset link:
#   ${FRONTEND_URL}/change-password?token=<token>
# Falls back to legacy CLIENT_URL if FRONTEND_URL is unset.
FRONTEND_URL=https://app.example.com

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins. Use "*" only in dev.
CORS_ORIGINS=http://localhost:3000

# ─── Admin bootstrap ─────────────────────────────────────────────────────────
# On first boot the AuthService seeds a single admin user if no admin exists.
# Both must be set; the password is hashed before being stored.
ADMIN_BOOTSTRAP_EMAIL=admin@tawal.local
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe!2025

# ─── Notes ───────────────────────────────────────────────────────────────────
# The HTTP port is hardcoded to 3000 in src/main.ts and is NOT env-controlled.
