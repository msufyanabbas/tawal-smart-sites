# ──────────────────────────────────────────────────────────────────────────────
# Root .env template for `docker compose up`.
# Combines every variable used by both services. Copy to `.env`, fill in
# real values, then run `docker compose up --build -d`.
# ──────────────────────────────────────────────────────────────────────────────

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║ Backend — cctv-backend-for-new (consumed inside the container at runtime) ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# MongoDB connection string. Use a managed Atlas URI in prod, e.g.
# mongodb+srv://user:pass@cluster.example.mongodb.net/cctv?retryWrites=true
MONGODB_URI=mongodb://mongo:27017/cctv

# JWT default-signing secret (auth.module.ts).
JWT_SECRET=change-me-jwt-default

# Short-lived access-token secret (15-minute tokens).
JWT_ACCESS_SECRET=change-me-access-secret

# Long-lived refresh-token secret (7-day tokens).
JWT_REFRESH_SECRET=change-me-refresh-secret

# SMTP credentials (nodemailer, port 465 SMTPS).
EMAIL_HOST=smtp.example.com
EMAIL=no-reply@example.com
EMAIL_PASSWORD=change-me-smtp-password

# Base URL of the public web client — used to build password-reset links.
CLIENT_URL=https://app.example.com

# Comma-separated list of allowed CORS origins for the API.
# In compose with the nginx proxy, requests are same-origin so the API is rarely
# called cross-origin — list every host the browser will hit directly.
CORS_ORIGINS=https://app.example.com

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║ Frontend — cctv-records-web (consumed at BUILD time, baked into bundle)  ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# Where the SPA sends API requests.
#   • "/api" (default) — same-origin, proxied by nginx to backend:3000.
#   • "https://api.example.com" — direct cross-origin; remember to add the web
#     origin to CORS_ORIGINS above.
VITE_API_BASE_URL=/api

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║ Host port mappings (compose only)                                         ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# Public HTTP port the nginx container binds on the host.
WEB_HTTP_PORT=80
# Public HTTPS port (only used once you enable TLS in nginx.conf + compose).
WEB_HTTPS_PORT=443
